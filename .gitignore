# ---------------------------------------------------------------------------
# Secrets and service account credentials (defense in depth — never commit)
# ---------------------------------------------------------------------------
# Anything resembling a credential file
credentials/*
!credentials/.gitkeep
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*-key.json
*_key.json
*-credentials.json
*_credentials.json
service-account*.json
service_account*.json
google-credentials*.json
google_credentials*.json
stock-prices-*.json
# Local env files (keep the template)
.env
.env.*
!.env.example
# Direnv, mise, etc.
.envrc
.tool-versions
.python-version

# ---------------------------------------------------------------------------
# Python: bytecode, build, packaging
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
sdist/
wheels/
share/python-wheels/
pip-log.txt
pip-delete-this-directory.txt
MANIFEST

# ---------------------------------------------------------------------------
# Python: virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
twitter_env/
.python-version
__pypackages__/

# ---------------------------------------------------------------------------
# Python: linters, type checkers, test runners, coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
.cache/
.hypothesis/
.benchmarks/
nosetests.xml
*.cover
*.py,cover

# ---------------------------------------------------------------------------
# Jupyter / IPython
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.nbconvert.ipynb
profile_default/
ipython_config.py
Notebooks/accounts.db
Notebooks/tweets.csv
Notebooks/model_1.ipynb

# ---------------------------------------------------------------------------
# Runtime state, logs, caches, working dirs (keep folder structure via .gitkeep)
# ---------------------------------------------------------------------------
logs/*
!logs/.gitkeep
*.log
*.log.*

cache/*
!cache/.gitkeep

temp/*
!temp/.gitkeep
tmp/
*.tmp
*.bak
*.swp.bak

state/*.json
!state/.gitkeep

# ---------------------------------------------------------------------------
# Ingestion data: generated parquet/csv files (keep archive folder shape)
# ---------------------------------------------------------------------------
Data/*.parquet
Data/archive/*.parquet
Data/archive/*.csv
Data/*.csv
!Data/archive/.gitkeep
*.parquet
*.feather

# Project-local stray data files
todo.txt
prompt_copy.txt

# ---------------------------------------------------------------------------
# ML artifacts: models, embeddings, checkpoints
# (Saved_Models/*.pt are intentionally tracked — see GitHub Releases workflow)
# ---------------------------------------------------------------------------
*.pkl
*.joblib
*.h5
*.hdf5
*.onnx
*.gguf
*.safetensors
*.npy
*.npz
checkpoints/
runs/
mlruns/
wandb/
.neptune/

# HuggingFace / Torch caches sometimes land in repo root if HF_HOME is unset
.cache/huggingface/
hf_cache/
torch_cache/

# Generated prediction outputs (keep folder shape)
outputs/main_inference/*
!outputs/main_inference/.gitkeep

# ---------------------------------------------------------------------------
# Databases
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.sqlite-journal
*.db
*.db-journal

# ---------------------------------------------------------------------------
