# =============================================================================
# Stock Market Automation — environment template
#
# Copy this to `.env` and fill in your secrets. `.env` is gitignored;
# `.env.example` is the committed reference. Keep the two in sync when you
# add new settings.
# =============================================================================


# -----------------------------------------------------------------------------
# Google Sheets / Cloud (REQUIRED)
# -----------------------------------------------------------------------------
# Path to the Google service account JSON for direct (non-Docker) runs.
# The repo's .gitignore already excludes credentials/*.json, so place the
# file under credentials/ locally and point this at it.
GOOGLE_CREDENTIALS=./credentials/your-service-account-here.json

# Just the filename portion of the credentials JSON — used by docker-compose
# to know which file under credentials/ to mount. The compose mount remaps
# it to a canonical /app/credentials/service-account.json inside the
# container, so the rest of the app doesn't care about the long filename.
CREDENTIALS_FILE=your-service-account-here.json

# The "real OHLCV" Google Sheet. Defaults to the project sheet if unset.
SHEET_ID=1uekPHyvJj4p6YBIAI71SWRye-xxFu47Kgpf9o

# (P2 — pending) The separate Google Sheet that will hold 30-day predicted
# price paths + Claude's trade signals. Provided by you once created.
# PREDICTIONS_SHEET_ID=

# Firestore project ID. Optional — if unset, the project is read from the
# service-account JSON pointed at by GOOGLE_CREDENTIALS. Set it explicitly
# when running in CI / Docker so we don't depend on JSON parsing.
FIRESTORE_PROJECT=your-gcp-project-id
# Collection name for fundamentals docs (P1.1). Doc id is `{TICKER}`
# (e.g. RELIANCE), with recent quarters nested under `quarters`.
FIRESTORE_FUNDAMENTALS_COLLECTION=fundamentals


# -----------------------------------------------------------------------------
# Reddit (anonymous JSON scrape — no API keys, since Reddit Data API access
# was rejected). The User-Agent is the only knob; Reddit's policy is to
# identify yourself honestly, so include a contact or repo name.
# -----------------------------------------------------------------------------
REDDIT_USER_AGENT=stock-market-automation/0.1 (anonymous scrape)


# -----------------------------------------------------------------------------
# Slack notifications (OPTIONAL)
# -----------------------------------------------------------------------------
# Leave empty to disable. When set, the workflow runner posts run summaries.
SLACK_WEBHOOK_URL=
SLACK_NOTIFY_SUCCESS=false
SLACK_NOTIFY_FAILURES=true


# -----------------------------------------------------------------------------
# Anthropic / Claude API (P3 — pending)
# -----------------------------------------------------------------------------
# Required once the Claude decision layer ships. Get a key at
# https://console.anthropic.com/. The cost cap below short-circuits a run
# if the pre-flight token estimate would exceed the budget.
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MAX_USD_PER_RUN=2


# -----------------------------------------------------------------------------
# OHLCV update job (Data_update.py)
# -----------------------------------------------------------------------------
UPDATE_START_DATE=2015-01-01
UPDATE_INTERVAL=1d


# -----------------------------------------------------------------------------
# Inference (main.py)
# -----------------------------------------------------------------------------
# PyTorch device. "auto" picks CUDA → MPS → CPU.
DEVICE=auto


# -----------------------------------------------------------------------------
# Sentiment pipeline (P1.5 — features/sentiment.py)
# -----------------------------------------------------------------------------
# FinBERT (~440MB) downloaded from HuggingFace on first run, then cached.
SENTIMENT_MODEL=ProsusAI/finbert
# How far back social/news ingest jobs reach. yfinance .news only returns
# ~30d regardless, X scraping is closer to ~7d.
SENTIMENT_BACKFILL_DAYS=90


# -----------------------------------------------------------------------------
# Ingestion collection toggles
# -----------------------------------------------------------------------------
# true  = fetch fresh data, stage it, then upload pending/new archive rows.
# false = skip fresh collection and only drain any pending Firestore archive.
COLLECT_FUNDAMENTALS=true
COLLECT_NEWS=true
COLLECT_REDDIT=true
COLLECT_X=true
REQUEST_MAX_RETRIES=5


# -----------------------------------------------------------------------------
# Parquet artifact paths (P1 + P2)
# -----------------------------------------------------------------------------
# These default to the BASE_DIR/Data/ folder; override only if you want to
# store ingested data elsewhere (e.g. a mounted volume).
FUNDAMENTALS_PATH=./Data/archive/fundamentals.parquet
NEWS_PATH=./Data/archive/news.parquet
REDDIT_PATH=./Data/archive/reddit_posts.parquet
X_PATH=./Data/archive/x_posts.parquet
SENTIMENT_PATH=./Data/archive/sentiment_features.parquet
INDICES_PATH=./Data/archive/indices.parquet


# -----------------------------------------------------------------------------
# Workflow orchestration (FastAPI + watcher)
# -----------------------------------------------------------------------------
# Watcher polls the sheet every N seconds. Lower = more responsive,
# higher = fewer API calls. Default 10s works for personal use.
WATCHER_POLL_SECONDS=10

# Subprocess runner (Data_update.py / main.py launched from the API).
SUBPROCESS_TIMEOUT_SECONDS=1800
SUBPROCESS_RETRIES=2

# Google Sheets retry policy.
GOOGLE_RETRIES=3
RETRY_BACKOFF_SECONDS=2.0

# Inter-service base URL inside docker-compose. Override only if you rename
# the api service or run it on a non-standard port.
API_BASE_URL=http://api:8000
API_TIMEOUT_SECONDS=30

# LangChain router mode. "deterministic" is the only supported mode today;
# Claude-backed routing arrives in P3.
LANGCHAIN_MODE=deterministic


# -----------------------------------------------------------------------------
# Paths (rarely overridden)
# -----------------------------------------------------------------------------
# Override only if you've moved the project layout. Defaults derive from
# BASE_DIR which is the repo root.
# BASE_DIR=
# LOGS_DIR=./logs
# APP_LOG_PATH=./logs/app.log
# ERROR_LOG_PATH=./logs/error.log
# OUTPUTS_DIR=./outputs
# OUTPUT_DIR=./outputs/main_inference
# MODEL_DIR=./outputs/Saved_Models
# METADATA_PATH=./outputs/pipeline_metadata.json
# WORKBOOK=./Data/nse_stock_data.xlsx
# WORKFLOW_STATE_PATH=./workflow_state.json
